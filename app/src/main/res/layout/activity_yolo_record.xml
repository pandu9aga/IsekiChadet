<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" >

            <!-- No Produksi and Tanggal Produksi -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No Produksi"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/edtNoProduksi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:background="@android:drawable/edit_text"
                        android:inputType="text" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tanggal Produksi"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/edtTglProduksi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:background="@android:drawable/edit_text"
                        android:inputType="date" />
                </LinearLayout>
            </LinearLayout>

            <!-- No Chasis Checksheet -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Chasis Checksheet"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
            <EditText
                android:id="@+id/edtNoChasisKanban"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:background="@android:drawable/edit_text"
                android:inputType="text" />

            <!-- No Chasis Scan (OCR) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Chasis Scan (OCR)"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
            <EditText
                android:id="@+id/edtNoChasisScan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:background="@android:drawable/edit_text"
                android:inputType="text" />

            <!-- Scan Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">
                <Button
                    android:id="@+id/scanQRBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Scan QR"
                    android:backgroundTint="#FFC0CB"
                    android:textColor="@android:color/white" />
                <Button
                    android:id="@+id/captureImgBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Scan Dokumen"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#FFC0CB"
                    android:textColor="@android:color/white" />
            </LinearLayout>

            <!-- Validation Error Div -->
            <LinearLayout
                android:id="@+id/validationErrorDiv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/holo_red_light"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone" >
                <TextView
                    android:id="@+id/validationErrorText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Step sebelumnya belum selesai."
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Image Preview -->
            <ImageView
                android:id="@+id/cameraImage"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="8dp"
                android:background="#CCCCCC"
                android:scaleType="fitCenter"
                android:src="@drawable/baseline_image_24" />

            <!-- Submit Button -->
            <Button
                android:id="@+id/submitBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Submit Data"
                android:layout_marginTop="12dp"
                android:backgroundTint="#FFC0CB"
                android:textColor="@android:color/white"
                android:enabled="false" />

            <!-- Badge Status -->
            <TextView
                android:id="@+id/statusBadge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textAlignment="center"
                android:textStyle="bold"
                android:paddingVertical="30dp"
                android:paddingHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_badge_default"
                android:textSize="50sp"
                android:textColor="@android:color/white"
                android:elevation="6dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="#FFC0CB"
        app:itemTextColor="#FFC0CB"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
